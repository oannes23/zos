# Zos Configuration
# Copy this file to config.yaml and adjust as needed

# General settings
data_dir: ./data
log_level: INFO
log_json: true

# Self-concept size limit (characters). Prevents unbounded growth.
# Current document is ~10,000 chars. Set to 0 to disable.
self_concept_max_chars: 15000

# Discord settings
discord:
  polling_interval_seconds: 60
  # Bot's own Discord user ID — auto-detected at runtime.
  # Set manually only if running the API without the bot (e.g., for UI/debugging).
  # bot_user_id: "123456789012345678"
  # Operators have access to slash commands like /status, /silence, /reflect-now
  operators:
    user_ids:
      # - "123456789012345678"  # Discord user IDs
    role_id: null  # Optional: Discord role ID that grants operator access

# Database settings
database:
  # Path relative to data_dir
  path: zos.db

# LLM Model Profiles
# Each profile defines a provider and model to use
models:
  profiles:
    # Base profiles — use alias (undated) model IDs so they auto-update
    simple:
      provider: anthropic
      model: claude-haiku-4-5
    moderate:
      provider: anthropic
      model: claude-sonnet-4-6
    complex:
      provider: anthropic
      model: claude-opus-4-6

    # Semantic aliases - reference other profiles
    default: moderate
    reflection: moderate
    conversation: moderate
    synthesis: complex
    self_reflection: complex
    review: simple
    vision: moderate

  providers:
    anthropic:
      api_key_env: ANTHROPIC_API_KEY
    openai:
      api_key_env: OPENAI_API_KEY

# Salience configuration
salience:
  # Topic caps - maximum salience per topic type
  caps:
    server_user: 100
    global_user: 150
    channel: 150
    thread: 50
    role: 80
    dyad: 80
    user_in_channel: 40
    dyad_in_channel: 30
    subject: 60
    emoji: 60
    self: 100

  # Earning weights per activity type
  weights:
    message: 1.0
    reaction: 0.5
    mention: 2.0
    reply: 1.5
    thread_create: 2.0
    dm_message: 1.5
    emoji_use: 0.5
    media_boost_factor: 1.2  # Multiplier for messages with media/links
    self_mention: 5.0  # Extra salience when Zos is directly @-mentioned
    name_mention: 3.0  # Salience when "zos" appears in text (not @-mention)

  # Global caps
  # global_dyad: 100
  # global_self: 200

  # Propagation and decay
  propagation_factor: 0.3
  global_propagation_factor: 0.3
  spillover_factor: 0.5
  initial_global_warmth: 5.0
  retention_rate: 1.5
  decay_threshold_days: 7
  decay_rate_per_day: 0.01
  warm_threshold: 1.0
  min_reflection_salience: 10.0  # Minimum salience for topic to be eligible for reflection
  cost_per_token: 0.001          # Salience cost per LLM token for reflection
  global_reflection_budget: 15.0 # Budget for global topics (cross-server/DM)

  # Budget allocation per group (must sum to ~1.0)
  budget:
    social: 0.30    # server users + dyads
    global: 0.15    # global users + global dyads
    spaces: 0.30    # channels + threads
    semantic: 0.15  # subjects
    culture: 0.10   # emoji

  # Self budget is separate
  self_budget: 20

# Image generation (requires OPENAI_API_KEY)
image:
  enabled: false          # Opt-in: set true to allow Zos to generate images
  model: dall-e-3
  size: 1024x1024         # 1024x1024, 1024x1792, 1792x1024
  quality: standard       # "standard" or "hd"

# Chattiness configuration
chattiness:
  enabled: false                    # Master switch
  operator_dm_only: true            # All output → operator DMs
  threshold: 25                     # Impulse threshold to trigger speech
  channel_impulse_per_message: 1.0
  channel_impulse_per_reaction: 0.5
  dm_impulse_per_message: 100.0     # Floods past threshold for immediate DM response
  subject_impulse_per_insight: 10.0
  name_mention_impulse: 3.0         # Impulse when "zos" appears in text
  self_impulse_per_message: 1.0    # Impulse from bot's own messages (0 to disable)
  heartbeat_interval_seconds: 30
  decay_threshold_hours: 1
  decay_rate_per_hour: 0.05
  review_enabled: true              # Self-review before sending

# Privacy settings
privacy:
  review_pass: private_context  # always | private_context | never
  first_contact_message: |
    I remember what people tell me. This shapes how I understand you over time.
    I won't share what you say in DMs in other contexts without good reason.
    If you'd prefer I not remember our conversations, let me know.

# Observation settings
observation:
  vision_enabled: true
  vision_rate_limit_per_minute: 10
  transcription_enabled: true           # Transcribe audio/video via OpenAI Whisper (requires OPENAI_API_KEY)
  transcription_rate_limit_per_minute: 10
  transcription_max_file_size_mb: 25    # Whisper API hard limit
  link_fetch_enabled: true
  youtube_transcript_enabled: true
  video_duration_threshold_minutes: 30
  backfill_hours: 24
  reaction_user_rate_limit_per_minute: 20
  media_queue_max_size: 100
  link_queue_max_size: 50
  link_rate_limit_per_minute: 5
  reaction_resync_hours: 24

# Scheduler settings
scheduler:
  timezone: UTC
  reflection_cron: "0 13 * * *"  # 1 PM UTC daily (~5 AM Pacific)

# Server-specific overrides (keyed by Discord server ID)
# servers:
#   "123456789012345678":
#     privacy_gate_role: "987654321098765432"
#     threads_as_topics: false
#     speech_channel: "channel-name"
#     speech_channel_impulse_modifier: 2.0  # Boost impulse earning (default 1.0)
#     chattiness:
#       threshold_min: 30
#       threshold_max: 80
